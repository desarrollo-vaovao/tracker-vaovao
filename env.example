# ─── Meta / Facebook ───────────────────────────────────────────────
# Token que defines tú y registras en el panel de Meta al crear el webhook.
META_VERIFY_TOKEN=cambia-esto-por-un-string-secreto
# App Secret de tu app de Meta (para validar la firma X-Hub-Signature-256).
META_APP_SECRET=tu_app_secret
# Versión de la Graph API. Súbela cuando Meta libere una nueva.
GRAPH_API_VERSION=v23.0

# ─── Base de datos ─────────────────────────────────────────────────
# Dev: SQLite. Prod: postgresql+psycopg://user:pass@host:5432/vaovao
DATABASE_URL=sqlite:///./vaovao.db

# ─── Google Sheets ─────────────────────────────────────────────────
# Ruta al JSON de la Service Account. Comparte cada Sheet de cliente
# con el email de esta cuenta (client_email del JSON) como Editor.
GOOGLE_SERVICE_ACCOUNT_FILE=./service-account.json

# ─── Email (SMTP por defecto, sirve con Gmail, Resend, SendGrid…) ──
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.tu-proveedor.com
SMTP_PORT=587
SMTP_USER=apikey-o-usuario
SMTP_PASSWORD=tu_password
SMTP_FROM=VaoVao Leads <leads@tudominio.com>
SMTP_USE_TLS=true
